# Copy this file to .env and fill real values.
SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:mysql://localhost:3306/twitter
DB_USERNAME=root
DB_PASSWORD=swayam12

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

JWT_SECRET=your-long-random-jwt-secret
JWT_ISSUER=api.twitter.com
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=86400
JWT_REFRESH_COOKIE_NAME=refreshToken
JWT_COOKIE_SECURE=true
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=lax
JWT_COOKIE_DOMAIN=localhost

FRONTEND_SUCCESS_REDIRECT=http://localhost:5173/auth/success
FRONTEND_FAILURE_REDIRECT=http://localhost:5173/auth/failure
